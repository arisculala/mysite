# Allow peer dep conflicts that were resolved with --legacy-peer-deps
# (needed because eslint-config-next has peer dep mismatches with eslint@8)
legacy-peer-deps=true

# Retry up to 5 times on network failures
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=300000

# Progress bar off — cleaner Docker build logs
progress=false
